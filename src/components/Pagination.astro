---
const { currentPage, totalPages, disablePrev, disableNext } = Astro.props;
interface Props {
  currentPage: number;
  totalPages: number;
  disablePrev: boolean;
  disableNext: boolean;
}
---

<div
  class="mt-12 flex items-center justify-between gap-4 rounded-3xl border border-white/10 bg-white/5 p-3 shadow-[0_18px_50px_rgba(15,23,42,0.25)] backdrop-blur-xl"
>
  <a
    href={`/articles?page=${currentPage - 1}`}
    class={`${disablePrev ? "pointer-events-none inline-flex items-center rounded-2xl border border-white/5 bg-white/5 px-4 py-2 text-sm font-medium text-slate-500" : "inline-flex items-center rounded-2xl border border-cyan-400/20 bg-cyan-400/10 px-4 py-2 text-sm font-medium text-cyan-100 transition hover:border-cyan-300/40 hover:bg-cyan-400/20 hover:text-white"}`}
  >
    Previous
  </a>
  <a
    href={`/articles?page=${currentPage + 1}`}
    class={`${disableNext ? "pointer-events-none inline-flex items-center rounded-2xl border border-white/5 bg-white/5 px-4 py-2 text-sm font-medium text-slate-500" : "inline-flex items-center rounded-2xl border border-cyan-400/20 bg-cyan-400/10 px-4 py-2 text-sm font-medium text-cyan-100 transition hover:border-cyan-300/40 hover:bg-cyan-400/20 hover:text-white"}`}
  >
    Next
  </a>
</div>
