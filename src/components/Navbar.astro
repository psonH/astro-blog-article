---
import { Image } from "astro:assets";
import logo from "../images/logo.png";
---

<nav
  class="sticky top-0 z-50 border-b border-white/10 bg-slate-950/70 text-white backdrop-blur-xl"
>
  <div
    class="mx-auto flex max-w-7xl flex-wrap items-center justify-between px-4 py-4 sm:px-6 lg:px-8"
  >
    <a href="/" class="flex items-center gap-3">
      <Image
        src={logo}
        class="h-12 w-12 rounded-2xl border border-white/10 bg-white/5 p-1 shadow-lg shadow-cyan-500/10"
        alt="Priyank's Lib Logo"
        width={55}
        height={55}
      />
      <span
        class="whitespace-nowrap text-xl font-semibold tracking-tight sm:text-2xl"
      >
        <span class="text-cyan-300">Priyank's</span> Lib
      </span>
    </a>
    <button
      data-collapse-toggle="navbar-default"
      type="button"
      class="inline-flex h-11 w-11 items-center justify-center rounded-2xl border border-white/10 bg-white/5 text-slate-200 transition hover:border-cyan-300/30 hover:bg-white/10 focus:outline-none focus:ring-2 focus:ring-cyan-300/30 md:hidden"
      aria-controls="navbar-default"
      aria-expanded="false"
    >
      <span class="sr-only">Open main menu</span>
      <svg
        class="h-5 w-5"
        aria-hidden="true"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 17 14"
      >
        <path
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M1 1h15M1 7h15M1 13h15"></path>
      </svg>
    </button>
    <div class="hidden w-full md:block md:w-auto" id="navbar-default">
      <ul
        class="mt-4 flex flex-col gap-2 rounded-3xl border border-white/10 bg-slate-900/80 p-3 text-white shadow-[0_20px_60px_rgba(15,23,42,0.35)] backdrop-blur-xl md:mt-0 md:flex-row md:items-center md:gap-2 md:border-0 md:bg-transparent md:p-0 md:shadow-none"
      >
        <li>
          <a
            href="/"
            class="block rounded-2xl px-4 py-2 text-sm font-medium text-slate-200 transition hover:bg-white/5 hover:text-cyan-200 md:text-base"
            aria-current="page">Home</a
          >
        </li>
        <li>
          <a
            href="/articles"
            class="block rounded-2xl px-4 py-2 text-sm font-medium text-slate-200 transition hover:bg-white/5 hover:text-cyan-200 md:text-base"
            >All Articles</a
          >
        </li>
        <li>
          <a
            href="/about"
            class="block rounded-2xl px-4 py-2 text-sm font-medium text-slate-200 transition hover:bg-white/5 hover:text-cyan-200 md:text-base"
            >About</a
          >
        </li>
      </ul>
    </div>
    <a
      href="https://github.com/psonH/astro-blog-article"
      target="_blank"
      rel="noreferrer"
      class="ml-4 hidden items-center gap-2 rounded-2xl border border-cyan-400/20 bg-cyan-400/10 px-4 py-2 text-sm font-medium text-cyan-100 transition hover:border-cyan-300/40 hover:bg-cyan-400/20 hover:text-white md:inline-flex"
    >
      <svg
        class="h-4 w-4"
        aria-hidden="true"
        viewBox="0 0 24 24"
        fill="currentColor"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          d="M12 2C6.48 2 2 6.58 2 12.26c0 4.53 2.87 8.37 6.84 9.73.5.09.68-.22.68-.48 0-.24-.01-.87-.01-1.71-2.78.62-3.37-1.38-3.37-1.38-.45-1.17-1.1-1.48-1.1-1.48-.9-.63.07-.62.07-.62 1 .07 1.53 1.05 1.53 1.05.89 1.55 2.34 1.1 2.91.84.09-.66.35-1.1.64-1.35-2.22-.26-4.56-1.14-4.56-5.08 0-1.12.39-2.04 1.03-2.76-.1-.26-.45-1.31.1-2.72 0 0 .84-.28 2.75 1.05A9.24 9.24 0 0 1 12 6.96c.85 0 1.71.12 2.51.35 1.9-1.33 2.74-1.05 2.74-1.05.55 1.41.2 2.46.1 2.72.64.72 1.02 1.64 1.02 2.76 0 3.95-2.34 4.82-4.57 5.07.36.32.68.96.68 1.94 0 1.4-.01 2.53-.01 2.88 0 .26.18.57.69.47A10.28 10.28 0 0 0 22 12.26C22 6.58 17.52 2 12 2Z"
        ></path>
      </svg>
      <span>Check the GitHub Repo</span>
    </a>
  </div>
</nav>
