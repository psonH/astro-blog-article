---
import { Image } from "astro:assets";
import logo from "../images/logo.png";
---

<nav
  class="sticky top-0 z-50 border-b border-white/10 bg-slate-950/70 text-white backdrop-blur-xl"
>
  <div
    class="mx-auto flex max-w-7xl flex-wrap items-center justify-between px-4 py-4 sm:px-6 lg:px-8"
  >
    <a href="/" class="flex items-center gap-3">
      <Image
        src={logo}
        class="h-12 w-12 rounded-2xl border border-white/10 bg-white/5 p-1 shadow-lg shadow-cyan-500/10"
        alt="Priyank's Lib Logo"
        width={55}
        height={55}
      />
      <span
        class="whitespace-nowrap text-xl font-semibold tracking-tight sm:text-2xl"
      >
        <span class="text-cyan-300">Priyank's</span> Lib
      </span>
    </a>
    <button
      data-collapse-toggle="navbar-default"
      type="button"
      class="inline-flex h-11 w-11 items-center justify-center rounded-2xl border border-white/10 bg-white/5 text-slate-200 transition hover:border-cyan-300/30 hover:bg-white/10 focus:outline-none focus:ring-2 focus:ring-cyan-300/30 md:hidden"
      aria-controls="navbar-default"
      aria-expanded="false"
    >
      <span class="sr-only">Open main menu</span>
      <svg
        class="h-5 w-5"
        aria-hidden="true"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 17 14"
      >
        <path
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M1 1h15M1 7h15M1 13h15"></path>
      </svg>
    </button>
    <div class="hidden w-full md:block md:w-auto" id="navbar-default">
      <ul
        class="mt-4 flex flex-col gap-2 rounded-3xl border border-white/10 bg-slate-900/80 p-3 text-white shadow-[0_20px_60px_rgba(15,23,42,0.35)] backdrop-blur-xl md:mt-0 md:flex-row md:items-center md:gap-2 md:border-0 md:bg-transparent md:p-0 md:shadow-none"
      >
        <li>
          <a
            href="/"
            class="block rounded-2xl px-4 py-2 text-sm font-medium text-slate-200 transition hover:bg-white/5 hover:text-cyan-200 md:text-base"
            aria-current="page">Home</a
          >
        </li>
        <li>
          <a
            href="/articles"
            class="block rounded-2xl px-4 py-2 text-sm font-medium text-slate-200 transition hover:bg-white/5 hover:text-cyan-200 md:text-base"
            >All Articles</a
          >
        </li>
        <li>
          <a
            href="/about"
            class="block rounded-2xl px-4 py-2 text-sm font-medium text-slate-200 transition hover:bg-white/5 hover:text-cyan-200 md:text-base"
            >About</a
          >
        </li>
      </ul>
    </div>
  </div>
</nav>
