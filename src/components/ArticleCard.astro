---
import { formatDate } from "../utils";
import type { CollectionEntry } from "astro:content";
import Tags from "./Tags.astro";
const { article } = Astro.props;
interface Props {
  article: CollectionEntry<"blog">;
}
---

<div class="max-w-md mx-auto mt-10">
  <div
    class="group h-full overflow-hidden rounded-3xl border border-white/10 bg-white/5 shadow-[0_20px_60px_rgba(15,23,42,0.35)] backdrop-blur-xl transition duration-300 hover:-translate-y-1 hover:border-cyan-300/30 hover:bg-white/10"
  >
    <a href={`/articles/${article.data.slug}`}>
      <img
        src={`/images/${article.data.image}`}
        alt="Article Image"
        class="h-52 w-full object-cover transition duration-500 ease-in-out group-hover:scale-105 group-hover:opacity-90"
      />
    </a>
    <div class="p-6">
      <h2
        class="mb-2 text-2xl font-semibold tracking-tight text-slate-50 transition group-hover:text-cyan-200"
      >
        <a href={`/articles/${article.data.slug}`}>
          {article.data.title}
        </a>
      </h2>
      <p class="mb-4 text-sm text-slate-300">
        {formatDate(article.data.pubDate)}
      </p>
      <Tags tags={article.data.tags} />
    </div>
  </div>
</div>
