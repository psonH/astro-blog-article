---
import MainLayout from "../layouts/MainLayout.astro";
import teamMember1 from "../images/team1.png";
import teamMember2 from "../images/team2.png";
import teamMember3 from "../images/team3.png";
import teamImage from "../images/about.jpg";
import { Image } from "astro:assets";
---

<MainLayout title="About Priyank's Lib">
  <div class="space-y-10">
    <section
      class="grid items-center gap-8 lg:grid-cols-[0.95fr_1.05fr] lg:gap-10"
    >
      <div
        class="space-y-6 rounded-4xl border border-white/10 bg-white/5 p-6 shadow-[0_20px_70px_rgba(15,23,42,0.25)] backdrop-blur-xl sm:p-8"
      >
        <p
          class="text-sm font-semibold uppercase tracking-[0.3em] text-cyan-200/80"
        >
          About us
        </p>
        <h1 class="text-4xl font-black tracking-tight text-white sm:text-5xl">
          About Priyank's Lib
        </h1>
        <p class="text-base leading-8 text-slate-300 sm:text-lg">
          We are a team of tech enthusiasts dedicated to practical coverage on
          software, devices, and the ideas shaping how people build today.
        </p>
        <p class="text-base leading-8 text-slate-300 sm:text-lg">
          Our goal is to help readers stay current without the noise, mixing
          useful context with clear explanations and a strong point of view.
        </p>
      </div>

      <div
        class="aspect-4/3 overflow-hidden rounded-4xl border border-white/10 bg-white/5 shadow-[0_30px_90px_rgba(15,23,42,0.35)] backdrop-blur-xl sm:aspect-16/10"
      >
        <Image
          src={teamImage}
          alt="Tech People Team"
          class="h-full w-full object-cover"
        />
      </div>
    </section>

    <section class="space-y-6">
      <div>
        <p
          class="text-sm font-semibold uppercase tracking-[0.3em] text-cyan-200/80"
        >
          Team
        </p>
        <h2
          class="mt-2 text-3xl font-bold tracking-tight text-white sm:text-4xl"
        >
          Meet the people behind the work.
        </h2>
      </div>

      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 xl:grid-cols-3">
        <article
          class="overflow-hidden rounded-4xl border border-white/10 bg-white/5 shadow-[0_20px_70px_rgba(15,23,42,0.25)] backdrop-blur-xl"
        >
          <Image
            src={teamMember1}
            alt="Team Member 1"
            class="h-72 w-full object-cover"
          />
          <div class="p-6">
            <h3 class="text-xl font-semibold text-white">John Doe</h3>
            <p class="mt-2 text-slate-300">Founder & Editor-in-Chief</p>
          </div>
        </article>
        <article
          class="overflow-hidden rounded-4xl border border-white/10 bg-white/5 shadow-[0_20px_70px_rgba(15,23,42,0.25)] backdrop-blur-xl"
        >
          <Image
            src={teamMember2}
            alt="Team Member 2"
            class="h-72 w-full object-cover"
          />
          <div class="p-6">
            <h3 class="text-xl font-semibold text-white">Paul Newman</h3>
            <p class="mt-2 text-slate-300">Lead Writer</p>
          </div>
        </article>
        <article
          class="overflow-hidden rounded-4xl border border-white/10 bg-white/5 shadow-[0_20px_70px_rgba(15,23,42,0.25)] backdrop-blur-xl"
        >
          <Image
            src={teamMember3}
            alt="Team Member 3"
            class="h-72 w-full object-cover"
          />
          <div class="p-6">
            <h3 class="text-xl font-semibold text-white">Johanna Johnson</h3>
            <p class="mt-2 text-slate-300">Tech Analyst</p>
          </div>
        </article>
      </div>
    </section>
  </div>
</MainLayout>
