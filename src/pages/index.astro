---
import MainLayout from "../layouts/MainLayout.astro";
import SearchForm from "../components/SearchForm.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import ArticleCard from "../components/ArticleCard.astro";
import MostRecentArticle from "../components/MostRecentArticle.astro";
import { HOMEPAGE_ARTICLE_LIMIT } from "../constants";

const allBlogArticles: CollectionEntry<"blog">[] = (
  await getCollection("blog")
).sort(
  (a: CollectionEntry<"blog">, b: CollectionEntry<"blog">) =>
    b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const mostRecentArticle: CollectionEntry<"blog"> = allBlogArticles[0];

const otherArticles: CollectionEntry<"blog">[] =
  allBlogArticles.length > 1 ? allBlogArticles.slice(1) : [];
---

<MainLayout title="Tech People Blog">
  <div class="space-y-16">
    <section
      class="grid items-center gap-8 lg:grid-cols-[1.05fr_0.95fr] lg:gap-10"
    >
      <div class="space-y-8">
        <div
          class="inline-flex items-center gap-2 rounded-full border border-cyan-400/20 bg-cyan-400/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.3em] text-cyan-100"
        >
          Fresh ideas for modern builders
        </div>
        <div class="space-y-5">
          <h1
            class="max-w-3xl text-5xl font-black leading-[0.95] tracking-tight text-white sm:text-6xl xl:text-7xl"
          >
            Articles, stories, and tutorials for tech people.
          </h1>
          <p class="max-w-2xl text-base leading-8 text-slate-300 sm:text-lg">
            Practical reads on software, devices, and the tools shaping how we
            build and work.
          </p>
        </div>

        <div class="max-w-2xl">
          <SearchForm />
        </div>
      </div>

      <MostRecentArticle article={mostRecentArticle} />
    </section>

    <section class="space-y-6">
      <div
        class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between"
      >
        <div>
          <p
            class="text-sm font-semibold uppercase tracking-[0.3em] text-cyan-200/80"
          >
            Latest articles
          </p>
          <h2
            class="mt-2 text-3xl font-bold tracking-tight text-white sm:text-4xl"
          >
            Explore recent stories.
          </h2>
        </div>
        <a
          href="/articles"
          class="inline-flex items-center justify-center rounded-2xl border border-white/10 bg-white/5 px-4 py-2 text-sm font-medium text-slate-100 transition hover:border-cyan-300/30 hover:bg-white/10 hover:text-white"
        >
          View all articles
        </a>
      </div>

      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 xl:grid-cols-3">
        {
          otherArticles
            .slice(0, HOMEPAGE_ARTICLE_LIMIT)
            .map((article) => <ArticleCard article={article} />)
        }
      </div>
    </section>
  </div>
</MainLayout>
